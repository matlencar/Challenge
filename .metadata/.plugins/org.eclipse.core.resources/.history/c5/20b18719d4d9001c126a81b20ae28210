package br.com.fiap.plataforma.model;

public class Dados {

	// Atributos
	private String usuario;
	private long senha;

	// Getters and Setters
	public String getUsuario() {
		return usuario;
	}

	public void setUsuario(String usuario) {
		this.usuario = usuario;
	}

	public long getSenha() {
		return senha;
	}

	public void setSenha(long senha) {
		this.senha = senha;
	}

}
